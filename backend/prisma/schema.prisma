// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  // Generate into the default top-level location so require('@prisma/client') can load the generated runtime
  output   = "../src/generated/prisma"
  moduleFormat    = "cjs"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int           @id @default(autoincrement())
  email        String        @unique
  passwordHash String
  name         String?
  avatarUrl    String?
  bio          String?
  createdAt    DateTime      @default(now())
  kpis         KPI[]
  friendsSent  Friend[]      @relation("sent")
  friendsRecv  Friend[]      @relation("recv")
  memberships  GroupMember[]
  activities   Activity[]
  kpilogs      KPILog[]
}

model Friend {
  id        Int          @id @default(autoincrement())
  requester Int
  receiver  Int
  status    FriendStatus @default(PENDING)
  createdAt DateTime     @default(now())

  requesterUser User @relation("sent", fields: [requester], references: [id])
  receiverUser  User @relation("recv", fields: [receiver], references: [id])
}

model Group {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  createdAt   DateTime @default(now())

  members    GroupMember[]
  groupKpis  KPI[]
  activities Activity[]
}

model GroupMember {
  id       Int       @id @default(autoincrement())
  groupId  Int
  userId   Int
  role     GroupRole @default(MEMBER)
  joinedAt DateTime  @default(now())

  group Group @relation(fields: [groupId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@unique([groupId, userId])
}

model Activity {
  id       Int  @id @default(autoincrement())
  userId   Int // User who performed the action
  groupId  Int? // If the activity is related to a group (scope: group)
  targetId Int? // For friend requests (target user ID)

  type           ActivityType
  kpiName        String? // Name of the KPI (for KPI creation/logging)
  kpiId          Int? // Reference to the KPI
  description    String? // Description (for KPI creation, group actions)
  groupName      String? // Name of the group (for group actions)
  completedTasks Int? // Number of completed tasks (for KPI log)

  createdAt DateTime @default(now())

  user  User   @relation(fields: [userId], references: [id])
  group Group? @relation(fields: [groupId], references: [id])

  @@index([userId])
  @@index([groupId])
  @@index([createdAt])
}

model KPI {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  type        KPIType
  scope       KPIScope

  userId  Int?
  groupId Int?

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  tasks KPITask[]

  user  User?  @relation(fields: [userId], references: [id])
  group Group? @relation(fields: [groupId], references: [id])

  @@index([scope])
  @@index([userId])
  @@index([groupId])
}

model KPITask {
  id       Int     @id @default(autoincrement())
  kpiId    Int
  name     String
  order    Int?
  isActive Boolean @default(true)

  scope   KPIScope
  groupId Int?

  kpi  KPI      @relation(fields: [kpiId], references: [id])
  logs KPILog[]

  @@index([kpiId])
  @@index([scope])
  @@index([groupId])
}

model KPILog {
  id        Int @id @default(autoincrement())
  kpiTaskId Int
  userId    Int

  scope   KPIScope
  groupId Int?

  completed Boolean
  loggedAt  DateTime @default(now())

  task KPITask @relation(fields: [kpiTaskId], references: [id])
  user User    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([groupId])
  @@index([scope])
  @@index([kpiTaskId])
}

enum KPIType {
  DAILY
  WEEKLY
  MONTHLY
}

enum KPIScope {
  PERSONAL
  GROUP
}

enum FriendStatus {
  PENDING
  ACCEPTED
  BLOCKED
}

enum ActivityType {
  KPI_LOG
  KPI_CREATED
  REQUEST_ADD_FRIEND
  FRIEND_REQUEST_ACCEPTED
  CREATE_GROUP
  JOIN_GROUP
  LEAVE_GROUP
}

enum GroupRole {
  ADMIN
  MEMBER
}
